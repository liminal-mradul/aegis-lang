// Aegis Codegen Test — test4.ae
// Tests that compile to real x86-64 assembly

use aegis::io;

// Simple functions
add :: (a: int, b: int) -> int {
    return a + b;
}

multiply :: (a: int, b: int) -> int {
    return a * b;
}

factorial :: (n: int) -> int {
    if n <= 1 { return 1; }
    return n * factorial(n - 1);
}

fib :: (n: int) -> int {
    if n <= 1 { return n; }
    return fib(n - 1) + fib(n - 2);
}

// Sum via loop
sum_range :: (lo: int, hi: int) -> int {
    var result: int = 0;
    for i in lo..hi {
        result += i;
    }
    return result;
}

// Count with while
count_down :: (n: int) -> int {
    var m: int = n;
    var k: int = 0;
    while m > 0 {
        m -= 1;
        k += 1;
    }
    return k;
}

// Ternary & comparison
max :: (a: int, b: int) -> int {
    return a > b ? a : b;
}

abs_val :: (x: int) -> int {
    return x < 0 ? -x : x;
}

// Inline asm
get_one_via_asm :: () -> int {
    asm {
        mov rax, 1;
    }
    return 0;
}

main :: () {
    // Arithmetic
    let x: int = 10;
    let y: int = 7;

    io::print(add(x, y));
    io::print(multiply(x, y));
    io::print(max(x, y));
    io::print(abs_val(-42));

    // Recursion
    io::print(factorial(6));
    io::print(fib(10));

    // Loops
    io::print(sum_range(1, 11));
    io::print(count_down(8));

    // Conditionals
    var a: int = 5;
    if a > 3 {
        io::print(a);
    } elif a == 3 {
        io::print(3);
    } else {
        io::print(0);
    }

    // Match
    match a {
        1 => io::print(1);
        5 => io::print(5);
        _ => io::print(0);
    }

    // Loop with break
    var k: int = 0;
    loop {
        k += 1;
        if k >= 10 { break; }
    }
    io::print(k);

    // Inline asm
    asm {
        nop;
    }
}

    io::print("");
    test_functions();
    io::print("");
    test_lambda();
    io::print("");
    test_match();
    io::print("");
    test_oop();
    io::print("");
    test_lists();
    io::print("");
    test_memory();
    io::print("");
    test_closures();

    io::print("");
    io::print("╔══════════════════════════════╗");
    io::print("║   All tests complete!        ║");
    io::print("╚══════════════════════════════╝");
}

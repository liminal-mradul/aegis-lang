// Aegis Codegen Full Test — test5.ae
// Tests all features that compile to native x86-64

use aegis::io;
use aegis::math;

// ══════════════════════════════════════════
//  Arithmetic & operators
// ══════════════════════════════════════════
test_arithmetic :: () -> int {
    let a: int = 100;
    let b: int = 37;
    let add_r   = a + b;        // 137
    let sub_r   = a - b;        // 63
    let mul_r   = a * b;        // 3700
    let div_r   = a / b;        // 2
    let mod_r   = a % b;        // 26
    let and_r   = a & b;        // 32
    let or_r    = a | b;        // 105
    let xor_r   = a ^ b;        // 73
    let neg_r   = -b;           // -37
    let not_r   = !0;           // 1
    let bnot_r  = ~0;           // -1
    io::print(add_r);
    io::print(sub_r);
    io::print(mul_r);
    io::print(div_r);
    io::print(mod_r);
    io::print(and_r);
    io::print(or_r);
    io::print(xor_r);
    io::print(neg_r);
    io::print(not_r);
    io::print(bnot_r);
    return 0;
}

// ══════════════════════════════════════════
//  Comparison & logic
// ══════════════════════════════════════════
test_logic :: () -> int {
    let x: int = 10;
    let y: int = 20;
    io::print(x < y);        // 1
    io::print(x > y);        // 0
    io::print(x == 10);      // 1
    io::print(x != y);       // 1
    io::print(x <= 10);      // 1
    io::print(y >= 20);      // 1
    io::print(x < y && y > 5);   // 1
    io::print(x > y || y > 5);   // 1
    io::print(!0);           // 1
    io::print(!!1);          // 1
    return 0;
}

// ══════════════════════════════════════════
//  Conditionals
// ══════════════════════════════════════════
test_conditionals :: () -> int {
    var x: int = 42;

    // if/elif/else
    if x > 50 {
        io::print(0);
    } elif x > 30 {
        io::print(1);    // ← this
    } else {
        io::print(2);
    }

    // ternary
    let r = x > 0 ? 7 : 8;
    io::print(r);           // 7

    // nested conditions as if/elif
    var grade: int = 0;
    if x >= 90 { grade = 5; }
    elif x >= 70 { grade = 4; }
    elif x >= 50 { grade = 3; }
    else { grade = 2; }
    io::print(grade);       // 2 (42 < 50)

    return 0;
}

// ══════════════════════════════════════════
//  Loops
// ══════════════════════════════════════════
test_loops :: () -> int {
    // for range sum
    var s: int = 0;
    for i in 1..11 {
        s += i;
    }
    io::print(s);           // 55

    // while countdown
    var n: int = 5;
    var prod: int = 1;
    while n > 0 {
        prod = prod * n;
        n -= 1;
    }
    io::print(prod);        // 120

    // loop with break
    var k: int = 0;
    loop {
        k += 1;
        if k >= 7 { break; }
    }
    io::print(k);           // 7

    // nested for
    var total: int = 0;
    for i in 0..4 {
        for j in 0..4 {
            total += 1;
        }
    }
    io::print(total);       // 16

    // continue
    var evens: int = 0;
    for i in 0..10 {
        if i % 2 != 0 { continue; }
        evens += 1;
    }
    io::print(evens);       // 5

    return 0;
}

// ══════════════════════════════════════════
//  Recursion
// ══════════════════════════════════════════
factorial :: (n: int) -> int {
    if n <= 1 { return 1; }
    return n * factorial(n - 1);
}

fib :: (n: int) -> int {
    if n <= 1 { return n; }
    return fib(n - 1) + fib(n - 2);
}

power :: (base: int, exp: int) -> int {
    if exp == 0 { return 1; }
    return base * power(base, exp - 1);
}

gcd :: (a: int, b: int) -> int {
    if b == 0 { return a; }
    return gcd(b, a % b);
}

test_recursion :: () -> int {
    io::print(factorial(7));        // 5040
    io::print(fib(12));             // 144
    io::print(power(2, 10));        // 1024
    io::print(gcd(48, 18));         // 6
    return 0;
}

// ══════════════════════════════════════════
//  Multiple return values via out-params
// ══════════════════════════════════════════
min_val :: (a: int, b: int) -> int {
    return a < b ? a : b;
}

max_val :: (a: int, b: int) -> int {
    return a > b ? a : b;
}

abs_val :: (x: int) -> int {
    return x < 0 ? -x : x;
}

clamp :: (val: int, lo: int, hi: int) -> int {
    if val < lo { return lo; }
    if val > hi { return hi; }
    return val;
}

test_helpers :: () -> int {
    io::print(min_val(5, 9));       // 5
    io::print(max_val(5, 9));       // 9
    io::print(abs_val(-42));        // 42
    io::print(clamp(150, 0, 100));  // 100
    io::print(clamp(-10, 0, 100));  // 0
    io::print(clamp(50, 0, 100));   // 50
    return 0;
}

// ══════════════════════════════════════════
//  Match
// ══════════════════════════════════════════
classify :: (n: int) -> int {
    match n {
        0     => return 0;
        1     => return 1;
        2..5  => return 2;
        5..10 => return 3;
        _     => return 4;
    }
}

test_match :: () -> int {
    io::print(classify(0));     // 0
    io::print(classify(1));     // 1
    io::print(classify(3));     // 2
    io::print(classify(7));     // 3
    io::print(classify(99));    // 4
    return 0;
}

// ══════════════════════════════════════════
//  Variable mutations
// ══════════════════════════════════════════
test_mutation :: () -> int {
    var x: int = 10;
    x += 5;   io::print(x);    // 15
    x -= 3;   io::print(x);    // 12
    x *= 2;   io::print(x);    // 24
    x /= 4;   io::print(x);    // 6
    x %= 4;   io::print(x);    // 2
    return 0;
}

// ══════════════════════════════════════════
//  Inline ASM
// ══════════════════════════════════════════
asm_add :: (a: int, b: int) -> int {
    var result: int = 0;
    asm(rdi = a, rsi = b, out rax = result) {
        mov rax, rdi;
        add rax, rsi;
    }
    return result;
}

test_asm :: () -> int {
    io::print(asm_add(30, 12));  // 42
    return 0;
}

// ══════════════════════════════════════════
//  Stress: deep recursion + arithmetic
// ══════════════════════════════════════════
sum_recursive :: (n: int) -> int {
    if n <= 0 { return 0; }
    return n + sum_recursive(n - 1);
}

test_stress :: () -> int {
    io::print(sum_recursive(100));   // 5050
    io::print(power(3, 8));          // 6561
    return 0;
}

// ══════════════════════════════════════════
//  main
// ══════════════════════════════════════════
main :: () {
    io::print(1111);
    test_arithmetic();
    io::print(2222);
    test_logic();
    io::print(3333);
    test_conditionals();
    io::print(4444);
    test_loops();
    io::print(5555);
    test_recursion();
    io::print(6666);
    test_helpers();
    io::print(7777);
    test_match();
    io::print(8888);
    test_mutation();
    io::print(9999);
    test_asm();
    io::print(1010);
    test_stress();
    io::print(0);
}

{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aegis",
  "scopeName": "source.aegis",
  "fileTypes": ["ae"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#function-decl" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.aegis", "match": "//.*$" },
        { "name": "comment.block.aegis", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aegis",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.aegis", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.aegis",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.aegis", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.aegis",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b|\\b\\d+([eE][+-]?\\d+)?\\b|\\b0[xX][0-9a-fA-F]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.aegis",
          "match": "\\b(if|elif|else|while|for|loop|match|in|break|continue|return|try|catch|throw)\\b"
        },
        {
          "name": "keyword.other.aegis",
          "match": "\\b(let|var|const|class|init|self|use|as|region|spawn|par|channel|send|recv|async|await|move|own|ref|mut|alloc|asm|allow|sandbox)\\b"
        },
        {
          "name": "constant.language.aegis",
          "match": "\\b(true|false|null|void)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.aegis",
          "match": "\\b(int|uint|float|bool|str|char|byte)\\b"
        },
        {
          "name": "entity.name.type.class.aegis",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "function-decl": {
      "patterns": [
        {
          "comment": "name :: ( ... ) -> Type {  — Aegis's function-declaration syntax",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(::)",
          "captures": {
            "1": { "name": "entity.name.function.aegis" },
            "2": { "name": "keyword.operator.decl.aegis" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.aegis",
          "match": "(->|=>|::|\\.\\.=|\\.\\.|&&|\\|\\||==|!=|<=|>=|\\+=|-=|\\*=|/=|[+\\-*/%<>=!&|^~?:.]|&)"
        }
      ]
    }
  }
}
